{
  "name": "@mipana-workspace/api-core-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "implicitDependencies": [
      "@mipana-workspace/api-core"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "api-core-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "@mipana-workspace/api-core:build",
          "@mipana-workspace/api-core:serve"
        ]
      }
    }
  }
}
